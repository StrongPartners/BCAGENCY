# ===========================================
# AI SEO Canavari - Ortam Degiskenleri
# ===========================================
# Bu dosyayi .env olarak kopyala ve degerleri doldur:
#   cp .env.example .env

# --- Genel ---
DEBUG=false

# --- Veritabani ---
DATABASE_URL=postgresql://seo_user:seo_pass@localhost:5432/ai_seo_db

# --- Google Search Console ---
# Service account JSON key dosyasinin yolu
GSC_SERVICE_ACCOUNT_FILE=gsc-service-account.json

# --- LLM API Keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GEMINI_API_KEY=AI...

# Varsayilan LLM (claude, openai, gemini)
DEFAULT_LLM=claude

# --- PageSpeed Insights ---
PAGESPEED_API_KEY=

# --- WordPress CMS ---
WP_URL=https://your-site.com
WP_USERNAME=admin
WP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Shopify CMS ---
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# --- Crawler Ayarlari ---
CRAWLER_MAX_PAGES=500
CRAWLER_DELAY=1.0
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_USER_AGENT=AI-SEO-Canavari/1.0

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# --- Redis (Celery icin) ---
REDIS_URL=redis://localhost:6379/0
